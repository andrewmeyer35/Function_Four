# ─── Supabase (already configured) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Anthropic (Claude vision + recipe extraction + meal suggestions) ────────
# Get from: platform.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Spoonacular (recipe search, autocomplete, findByIngredients) ────────────
# Get from: spoonacular.com/food-api → Get Started Free
# Free tier: 150 requests/day (plenty for development)
SPOONACULAR_API_KEY=your-key-here

# ─── Instacart Developer Platform (cart generation) ──────────────────────────
# Apply at: instacart.com/company/business/developers (~1 week for dev key)
# Sandbox base URL: https://connect.dev.instacart.tools
# Production base URL: https://connect.instacart.com
INSTACART_API_KEY=your-key-here
INSTACART_BASE_URL=https://connect.dev.instacart.tools

# ─── Vercel Cron secret (protects cron endpoints from public access) ─────────
# Generate: openssl rand -base64 32  (or any random string)
CRON_SECRET=your-random-secret-here
